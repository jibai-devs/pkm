# agent_000_dragapult — self-contained PPO self-play trainer.
# All recipes run from the repo root so `python -m` resolves the `pkm` package.
# Artifacts land in <repo>/pkm_data/new_agents/agent_000_dragapult/.

root := justfile_directory() / "../../.."
cli  := "uv run pkm new_agents 000_dragapult"

# List available recipes.
default:
    @just --list --unsorted

# Show default config, engine backend, and artifact paths.
info:
    cd {{root}} && {{cli}} info

# Training/eval recipes default to the fast local-nix engine (no kaggle_environments
# import). Override per-recipe: `just train engine=kaggle` / `engine=local`.

# Tiny end-to-end sanity run (2 updates x 2 games). Proves the pipeline works.
smoke workers="1" engine="local-nix":
    cd {{root}} && {{cli}} smoke --workers {{workers}} --engine {{engine}}

# PPO self-play training. e.g. `just train updates=200 games=16 workers=8`.
train updates="200" games="16" workers="1" engine="local-nix":
    cd {{root}} && {{cli}} train --updates {{updates}} --games {{games}} --workers {{workers}} --engine {{engine}}

# Resume from checkpoints/latest.pt for more updates.
resume updates="50" games="16" workers="1" engine="local-nix":
    cd {{root}} && {{cli}} resume --updates {{updates}} --games {{games}} --workers {{workers}} --engine {{engine}}

# Win-rate of the latest checkpoint vs the random baseline.
eval games="100" engine="local-nix":
    cd {{root}} && {{cli}} eval --games {{games}} --engine {{engine}}

# Launch TensorBoard over this agent's runs/ dir.
tensorboard port="6006":
    cd {{root}} && uv run tensorboard --logdir=pkm_data/new_agents/agent_000_dragapult/runs --port {{port}}

# Optuna hyperparameter sweep. e.g. `just sweep trials=30 updates=15 games=32 workers=8`.
sweep trials="30" updates="15" games="32" workers="8" engine="local-nix":
    cd {{root}} && {{cli}} sweep --trials {{trials}} --updates {{updates}} --games {{games}} --workers {{workers}} --engine {{engine}}

# Backfill TensorBoard from an existing train.csv (-> runs/csv-import/).
import-csv:
    cd {{root}} && {{cli}} import-csv

# Pack the latest weights into a Kaggle submission bundle (.tar.gz).
pack:
    cd {{root}} && {{cli}} pack

# Upload the newest packed bundle to Kaggle. e.g. `just submit message="v1"`.
submit message="agent_000_dragapult":
    cd {{root}} && {{cli}} submit --message "{{message}}"

# Poll Kaggle for submission status + score. `just status --watch` to poll.
status *args:
    cd {{root}} && {{cli}} status {{args}}
